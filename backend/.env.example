PORT=3001
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/habittracker

# JWT
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# Resend (email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=HabitTracker <noreply@yourdomain.com>

# Frontend URL (for CORS + password reset links)
FRONTEND_URL=http://localhost:5173

# Cron job secret (for /api/reminders/send)
CRON_SECRET=change-this-too
